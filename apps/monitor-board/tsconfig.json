{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@monitor/protocol": ["./src/monitor/protocol/index.ts"],
      "@monitor/runtime-store": ["./src/monitor/runtime-store/index.ts"],
      "@monitor/monitor-gateway": ["./src/monitor/gateway/index.ts"],
      "@monitor/monitor-skill": ["./src/monitor/skill/index.ts"],
      "@monitor/host-coco-hook": ["./src/monitor/host-coco/index.ts"],
      "@monitor/host-claude-code-hook": ["./src/monitor/host-claude/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts", "vitest.config.ts"]
}
